{
    "buildCommand": "bash vercel-build.sh",
    "installCommand": "composer install --no-dev --optimize-autoloader --no-interaction && npm install",
    "outputDirectory": "public",
    "functions": {
        "api/lambda.php": {
            "runtime": "vercel-php@0.7.4"
        }
    },
    "rewrites": [
        {"source": "/(.*)", "destination": "api/lambda.php"}
    ]
}
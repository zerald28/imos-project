{
    "buildCommand": "bash vercel-build.sh",
    "installCommand": "npm install",
    "outputDirectory": "public",
    "functions": {
        "api/lambda.php": {
            "runtime": "vercel-php@0.7.4"
        }
    },
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/build/$1"
        },
        {
            "src": "/storage/(.*)",
            "dest": "/storage/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/lambda.php"
        }
    ]
}
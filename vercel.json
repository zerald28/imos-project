{
  "$schema": "https://openapi.vercel.app/schema.json",
  "buildCommand": "composer install --no-dev --optimize-autoloader && npm ci && npm run build && php artisan optimize",
  "installCommand": "composer install --no-dev --optimize-autoloader && npm ci",
  "framework": null,
  "nodeVersion": "22.x",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.4"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}